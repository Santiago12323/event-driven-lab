{
    "name": "UBUNTU Spring Boot RabbitMQ Lab",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "moby": true,
            "dockerDashComposeVersion": "v2"
        },
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17",
            "installMaven": true,
            "installGradle": false
        }
    },
    "forwardPorts": [
        8080,
        15672,
        5672
    ],
    "portsAttributes": {
        "8080": {
            "label": "Producer API",
            "onAutoForward": "notify"
        },
        "15672": {
            "label": "RabbitMQ UI",
            "onAutoForward": "notify"
        },
        "5672": {
            "label": "RabbitMQ AMQP",
            "onAutoForward": "silent"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vmware.vscode-spring-boot",
                "ms-azuretools.vscode-docker",
                "redhat.java",
                "pivotal.vscode-spring-boot",
                "vscjava.vscode-maven"
            ]
        }
    },
    "postCreateCommand":"echo '✅ Codespace listo!'",
    "remoteUser": "vscode",
    "remoteEnv": {
        "DOCKER_BUILDKIT": "1"
    }
}
